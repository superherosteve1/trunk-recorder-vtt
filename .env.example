# sdr-trunk-vtt configuration
# Copy to .env and adjust for your network

# Port exposed on the host
VTT_PORT=8080

# API key for Trunk Recorder upload script (Bearer token)
API_KEY=change-me-to-a-secret

# Optional: Postgres for calls. When unset, use SQLite at
# {DATA_DIR}/calls.db. Schema DDL: docs/postgres-schema.sql
# DATABASE_URL=postgresql://vtt:PASSWORD@your-ip:your-port/vtt
# DATABASE_SCHEMA=your-schema

# Primary backend: openai | faster_whisper
# - openai: OpenAI-compatible /v1/audio/transcriptions endpoint
# - faster_whisper: faster-whisper HTTP server
TRANSCRIPTION_BACKEND=openai

# If primary backend fails, try the other one
TRANSCRIPTION_FALLBACK=true

# OpenAI-compatible Whisper endpoint on your network
WHISPER_API_URL=http://192.168.1.100:9000/v1/audio/transcriptions
WHISPER_API_KEY=
WHISPER_MODEL=whisper-1
WHISPER_LANGUAGE=en
# Base dispatch boilerplate; local spellings live in whisper-jargon.txt (see README).
WHISPER_PROMPT="Police fire EMS dispatch scanner radio. 10-4, copy, en route, responding, medic, unit, code."
# Optional override; default is /data/whisper-jargon.txt in the container / on NFS.
# WHISPER_JARGON_PATH=/data/whisper-jargon.txt

# faster-whisper HTTP endpoint on your network
FASTER_WHISPER_API_URL=http://192.168.1.100:8000/transcribe
FASTER_WHISPER_LANGUAGE=en

# Skip calls shorter than this many seconds
MIN_CALL_LENGTH=2

# Transcription request timeout (seconds)
TRANSCRIPTION_TIMEOUT=300

# Retry failed transcriptions up to this many times
MAX_RETRIES=3

# Encrypted-call public-records clipboard helper (CORA/FOIA/etc.)
RECORDS_REQUEST_ENABLED=true
RECORDS_REQUEST_BUTTON_LABEL=CORA
RECORDS_REQUEST_TITLE=CORA (Colorado Open Records Act) audio retrieval request
RECORDS_REQUEST_CONTACT_LABEL=CORA

# Site branding (defaults = Denver/Aurora; change for other municipalities)
SITE_TITLE=Denver / Aurora Trunk Monitor
SITE_SUBTITLE=Trunk Recorder transcription dashboard
# SITE_NOTICE=   # optional override of the header legal/ops notice
SITE_SHOW_RECORDS_HELP=true

# District map: edit config/districts.json + GIS/*.geojson (see README).
# Optional override of the config file path inside the container:
# DISTRICTS_CONFIG_PATH=/data/districts.json

# After transcription, recompress WAV for storage (requires ffmpeg in the container)
AUDIO_COMPRESS=true
AUDIO_FORMAT=mp3
AUDIO_BITRATE=32k

# --- Deployment modes ---
# All-in-one Docker (default): API queues uploads and runs the Whisper worker.
# TRANSCRIPTION_WORKER_ENABLED=true
#
# Edge transcribe + cloud archive API: Whisper stays on the LAN; the API only
# stores audio + transcript for the dashboard. Set false on the cloud API so
# uploads without a transcript are rejected (HTTP 400) instead of sitting pending.
# TRANSCRIPTION_WORKER_ENABLED=false
#
# Trunk Recorder on the edge should use scripts/upload-transcribed.sh (or set
# VTT_LOCAL_TRANSCRIBE=1 with scripts/upload.sh). Point VTT_API_URL at the cloud API
# and WHISPER_API_URL at your local OpenAI-compatible Whisper endpoint.
# VTT_LOCAL_TRANSCRIBE=0
# VTT_API_URL=https://your-cloud-api.example.com
# WHISPER_API_URL=http://127.0.0.1:9000/v1/audio/transcriptions
# TRANSCRIPTION_TIMEOUT=300

# --- Encrypted upload reject gate (POST /calls) ---
# Honest Trunk Recorder never uploads encrypted WAVs. These defaults reject
# misconfigured/malicious feeders that still POST encrypted-looking audio.
# Metadata-only activity stays on POST /events/encrypted (unchanged).
# REJECT_ENCRYPTED_UPLOADS=true
# REJECT_ENCRYPTED_AUDIO_ENTROPY=true
# ENCRYPTED_AUDIO_ENTROPY_THRESHOLD=7.5

# Dashboard / dossier local-time labels (also used when formatting CORA packets).
# Keep aligned with TR_LOCAL_TIMEZONE on the Trunk Recorder host (default America/Denver).
# SITE_TIMEZONE=America/Denver
